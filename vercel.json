{
  "name": "SecurePay-AI",
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "redirects": [
    { "src": "/", "dest": "/frontend/", "permanent": true }
  ]
}
